# PyDocFlow Environment Configuration

## Database configuration
MONGO_USER=admin
MONGO_PASSWORD=secret
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=ocr_db

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ocr_db

## OCR configuration
TESSERACT_PATH=/usr/local/bin/tesseract
TESSERACT_LANG=ara

## LLM configuration
LLM_PROVIDER=ollama
LLM_MODEL=granite4:latest
LLM_OLLAMA_HOST=http://localhost:11434

LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=120
